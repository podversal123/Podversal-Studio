# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/podversal"

# ─────────────────────────────────────────
# REDIS (slot locking)
# Local development  → use REDIS_HOST + REDIS_PORT (Docker)
# Production (Render) → use REDIS_URL only (Upstash)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# Upstash Redis URL (production only — leave empty for local)
# Get this from upstash.com → Create Database → Copy REST URL
REDIS_URL=

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─────────────────────────────────────────
# OTP (MSG91)
# ─────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_template_id
MSG91_SENDER_ID=PODVRS

# ─────────────────────────────────────────
# EMAIL (Nodemailer)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_studio_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Podversal Studio <your_studio_email@gmail.com>"

# ─────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─────────────────────────────────────────
# CLOUDINARY (PDF & file storage)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
