# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Supabase: use the "Transaction pooler" URL here
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/podversal?pgbouncer=true"
# Supabase: use the "Session pooler" or "Direct connection" URL here (for Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/podversal"

# ─────────────────────────────────────────
# REDIS (slot locking)
# Local development  → use REDIS_HOST + REDIS_PORT (Docker)
# Production (Render) → use REDIS_URL only (Upstash)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# Upstash Redis URL (production only  leave empty for local)
# Get this from upstash.com → Create Database → Copy REST URL
REDIS_URL=

# ─────────────────────────────────────────
# FIRST-TIME ADMIN SETUP
# Required to create the first Super Admin at /setup.
# Generate a random value and set the SAME one in production.
# ─────────────────────────────────────────
SETUP_SECRET=change_me_to_a_random_string

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─────────────────────────────────────────
# OTP (2Factor.in)
# Get API key from dashboard.2factor.in
# ─────────────────────────────────────────
TWO_FACTOR_API_KEY=your_2factor_api_key

# ─────────────────────────────────────────
# EMAIL (Nodemailer)
# ─────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@podversal.com       # sending address (Hostinger mailbox)
SMTP_PASS=your_smtp_password
EMAIL_FROM="Podversal Studio <noreply@podversal.com>"

# Inbox that receives contact form enquiries, new booking alerts, payment alerts, shoot reminders
ADMIN_EMAIL=podversalstudio@gmail.com

# Logo shown in all emails  must be a public URL (Cloudinary recommended)
# Leave empty to show text "PODVERSAL STUDIO" instead
EMAIL_LOGO_URL=

# ─────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─────────────────────────────────────────
# CLOUDINARY (PDF & file storage)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
